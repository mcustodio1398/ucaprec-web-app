NODE_ENV=production
PORT=4000

# URL del frontend institucional, por ejemplo:
# https://ucaprec.pgr.gob.do
CORS_ORIGIN=http://localhost:5173

# PostgreSQL institucional
DATABASE_URL=postgres://ucaprec_app:CAMBIAR_PASSWORD@localhost:5432/ucaprec
DATABASE_SSL=false

# Cambiar por una cadena larga, privada y aleatoria
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_DE_64_CARACTERES
JWT_EXPIRES_IN=8h

# Carpeta local o ruta de red para documentos
UPLOAD_DIR=./storage/documentos
MAX_FILE_MB=25
